# Weather Trading Bot — environment variables
# Copy to .env and fill in your values

# ── Trading mode ──────────────────────────────────────────────────────────────
PAPER_MODE=true           # Set to false for live trading

# ── Capital ───────────────────────────────────────────────────────────────────
BANKROLL=1000.0           # Starting bankroll in USD
DAILY_LOSS_LIMIT=50.0     # Stop trading after this much loss in a day

# ── Scheduling ────────────────────────────────────────────────────────────────
POLL_INTERVAL_S=300       # Seconds between scan cycles (default: 5 minutes)

# ── NWS Settlement (required for calibration) ─────────────────────────────────
NOAA_CDO_TOKEN=           # Free token from https://www.ncdc.noaa.gov/cdo-web/token

# ── Kalshi (only required for live trading) ───────────────────────────────────
KALSHI_KEY_ID=            # API key ID from kalshi.com account settings
KALSHI_PRIVATE_KEY_PATH=  # Path to your RSA private key .pem file

# ── Database ──────────────────────────────────────────────────────────────────
DB_PATH=data/bot.db       # SQLite database file path
